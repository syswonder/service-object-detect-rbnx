# Request: grasp pose detection with 2D ROI constraint
string object_name

# 2D bounding box in pixel coordinates [x_min, y_min, x_max, y_max]
# Used to filter grasp poses by projecting 3D pose back to 2D image
float64[] bbox_2d

# 3D center position of the object in camera frame [x, y, z]
# Used to filter grasp poses by 3D distance
float64[] object_center_3d

# retry count
int32 retry

---
# Response: best grasp pose for the object within the 2D ROI

# Grasp pose in camera_color_optical_frame
geometry_msgs/PoseStamped grasp_pose

# Gripper width in meters
float32 gripper_width

# Grasp quality score
float32 score

# Success flag
bool success

# Status message
string message
